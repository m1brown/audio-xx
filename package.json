{
  "name": "audio-xx",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/web",
    "build": "npm run build --workspace=apps/web",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "npm run typecheck --workspace=apps/web && npm run typecheck --workspace=packages/rules",
    "lint": "eslint . --ext .ts,.tsx",
    "db:generate": "npm run db:generate --workspace=apps/web",
    "db:push": "npm run db:push --workspace=apps/web",
    "db:seed": "npm run db:seed --workspace=apps/web"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "eslint": "^9.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@libsql/isomorphic-fetch": "^0.3.1",
    "@sentry/nextjs": "^10.51.0",
    "async-mutex": "^0.5.0"
  }
}
