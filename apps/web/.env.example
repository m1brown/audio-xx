DATABASE_URL="file:./dev.db"
TURSO_DATABASE_URL=""
TURSO_AUTH_TOKEN=""
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
MEMO_LLM_PROVIDER=openai
OPENAI_API_KEY=""
MEMO_LLM_MODEL=gpt-4o

# ── Affiliate / partner-network identifiers ────────────
# Centralized via apps/web/src/lib/affiliate-config.ts. When unset,
# outbound URLs are generated WITHOUT the affiliate parameter —
# this keeps dev / preview / forked deployments from polluting the
# production account's affiliate traffic. Set per-environment in
# Vercel for production / preview; use .env.local for local dev.
#
# AMAZON_AFFILIATE_TAG: Amazon Associates store ID. When set,
#   populates the `tag=` query parameter on Amazon search URLs.
#   This is a public identifier (appears in every outbound URL) —
#   NOT a credential. Safe to set directly in Vercel env vars.
#   Example: "audioxx20-20"
AMAZON_AFFILIATE_TAG=""

# EBAY_CAMPAIGN_ID: eBay Partner Network campaign ID. When set,
#   appends `campid=<value>` to outbound eBay search URLs via the
#   ebay-links helper. Plain (untagged) URLs when unset.
#   Example: "5339152664"
EBAY_CAMPAIGN_ID=""

# EBAY_CUSTOM_ID: Optional EPN custom tracking ID. When set AND
#   EBAY_CAMPAIGN_ID is also set, appends `customid=<value>` to
#   outbound eBay search URLs. Useful for bucketing attribution by
#   sub-source. Ignored when EBAY_CAMPAIGN_ID is unset.
#   Example: "Audioxx"
EBAY_CUSTOM_ID=""

# EBAY_HOST: eBay marketplace host. Defaults to "www.ebay.com" when
#   unset — Audio XX is U.S.-centered by default, Europe-aware via
#   single-host override. Per-environment override to redirect
#   outbound used-market links to a different marketplace
#   (www.ebay.co.uk, www.ebay.fr, etc.). Single-host configuration
#   only — no UI selector, no geo-routing.
EBAY_HOST=""

# ── Debug / observability ──────────────────────────────
# Set to "1" to keep tagged debug console.log calls visible in the
# browser. Anything else (default) silences them. Local dev usually =1.
NEXT_PUBLIC_DEBUG=""

# Sentry — leave blank to disable (Sentry initializes as a no-op).
# Friends/journalist deploys should set these in the Vercel project env.
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_ENVIRONMENT="production"
SENTRY_ENVIRONMENT="production"
# Source-map upload (CI / Vercel build only — not needed locally):
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
